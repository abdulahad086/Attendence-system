# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://attend_user:attend_pass@localhost:5432/attendance_db

# ── Face Recognition ──────────────────────────────────────────────────────────
DEEPFACE_MODEL=ArcFace
SIMILARITY_THRESHOLD=0.40
MIN_FACE_SIZE=60

# ── Attendance ────────────────────────────────────────────────────────────────
# ATTENDANCE SETTINGS
# ────────────────────────────────────────────────────────────

# Time before which an employee is considered 'present' (HH:MM format)
EXPECTED_START_TIME=09:15

# Minutes before the same user can be marked again (duplicate guard)
ATTENDANCE_COOLDOWN_MINUTES=5

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production

# ── Storage ───────────────────────────────────────────────────────────────────
FACE_IMAGES_DIR=data/face_images
